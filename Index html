<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Sunday Meeting App</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#2a5ab9">

<style>
    body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial;
        background: #e9eef3;
        margin: 0;
        padding: 0;
    }

    .app-header {
        background: #2a5ab9;
        color: white;
        padding: 18px;
        text-align: center;
        font-size: 22px;
        font-weight: 600;
        position: sticky;
        top: 0;
        z-index: 10;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }

    .container {
        padding: 15px;
        max-width: 600px;
        margin: auto;
    }

    .week {
        background: white;
        padding: 18px;
        margin-bottom: 18px;
        border-radius: 14px;
        box-shadow: 0 3px 8px rgba(0,0,0,0.12);
    }

    .week h2 {
        margin-top: 0;
        font-size: 18px;
        color: #2a5ab9;
        font-weight: 600;
    }

    label {
        font-weight: 600;
        font-size: 14px;
        color: #333;
    }

    input {
        width: 100%;
        padding: 12px;
        margin: 6px 0 16px 0;
        border-radius: 10px;
        border: 1px solid #bbb;
        font-size: 16px;
        background: #f9f9f9;
    }
</style>
</head>

<body>

<div class="app-header">Sunday Meeting Scheduler</div>

<div class="container" id="calendar"></div>

<script>
function getSundays() {
    const sundays = [];
    const today = new Date();
    const end = new Date(today.getFullYear(), 11, 31);

    let current = new Date(today);
    current.setDate(current.getDate() + (7 - current.getDay()) % 7);

    while (current <= end) {
        sundays.push(new Date(current));
        current.setDate(current.getDate() + 7);
    }
    return sundays;
}

function loadSaved(id) {
    return localStorage.getItem(id) || "";
}

function saveField(id, value) {
    localStorage.setItem(id, value);
}

function buildCalendar() {
    const container = document.getElementById("calendar");
    const sundays = getSundays();

    sundays.forEach((date, index) => {
        const idPrefix = "week" + index;

        const div = document.createElement("div");
        div.className = "week";

        div.innerHTML = `
            <h2>${date.toDateString()}</h2>

            <label>Title of Talk</label>
            <input id="${idPrefix}_talk" value="${loadSaved(idPrefix + '_talk')}"
                oninput="saveField('${idPrefix}_talk', this.value)">

            <label>Opening Song</label>
            <input id="${idPrefix}_song" value="${loadSaved(idPrefix + '_song')}"
                oninput="saveField('${idPrefix}_song', this.value)">

            <label>Speaker</label>
            <input id="${idPrefix}_speaker" value="${loadSaved(idPrefix + '_speaker')}"
                oninput="saveField('${idPrefix}_speaker', this.value)">

            <label>Congregation</label>
            <input id="${idPrefix}_cong" value="${loadSaved(idPrefix + '_cong')}"
                oninput="saveField('${idPrefix}_cong', this.value)">

            <label>Chairman</label>
            <input id="${idPrefix}_chair" value="${loadSaved(idPrefix + '_chair')}"
                oninput="saveField('${idPrefix}_chair', this.value)">

            <label>Watchtower Reader</label>
            <input id="${idPrefix}_reader" value="${loadSaved(idPrefix + '_reader')}"
                oninput="saveField('${idPrefix}_reader', this.value)">
        `;

        container.appendChild(div);
    });
}

buildCalendar();

if ("serviceWorker" in navigator) {
    navigator.serviceWorker.register("service-worker.js");
}
</script>

</body>
</html>
